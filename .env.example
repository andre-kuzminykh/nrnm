# ── Telegram ─────────────────────────────────────────────────────
BOT_TOKEN=

# ── LLM (OpenAI-compatible API) ──────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

# ── RAG (Qdrant Cloud) ───────────────────────────────────────────
# Optional — if empty, domains/model selection still work but ingest/query
# become no-ops and the UI shows a "⚠️ RAG не сконфигурирован" notice.
QDRANT_URL=
QDRANT_API_KEY=

# Embedding model for RAG chunks
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Health server ────────────────────────────────────────────────
# Port the bot exposes GET /health on. Used by docker-compose healthcheck
# and external probes (GCE, uptime monitors). Must match `ports:` in
# docker-compose.yml if you publish it to the host.
HEALTH_PORT=8003

# ── Tool layer: web_search via SerpAPI (optional) ────────────────
# Provider key for the v1 web_search tool. If empty the tool falls
# back to a deterministic stub (fake hits) — useful for local dev
# and CI. Set this to your SerpAPI key to enable real searches.
SERPAPI_API_KEY=
SERPAPI_ENDPOINT=https://serpapi.com/search
SERPAPI_ENGINE=google
SERPAPI_TIMEOUT=8.0
